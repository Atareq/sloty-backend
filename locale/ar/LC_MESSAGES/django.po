#: apps/audit/models.py:11
msgid "Booking created"
msgstr "تم إنشاء الحجز"

#: apps/audit/models.py:12
msgid "Booking updated"
msgstr "تم تعديل الحجز"

#: apps/audit/models.py:13
msgid "Booking cancelled"
msgstr "تم إلغاء الحجز"

#: apps/audit/models.py:14
msgid "Booking completed"
msgstr "تم إكمال الحجز"

#: apps/audit/models.py:15
msgid "Booking no-show"
msgstr "تم تسجيل عدم الحضور"

#: apps/audit/models.py:16
msgid "Booking expired"
msgstr "انتهت صلاحية الحجز"

#: apps/audit/models.py:17
msgid "Booking rescheduled"
msgstr "تمت إعادة جدولة الحجز"

#: apps/audit/models.py:18
msgid "Transaction created"
msgstr "تم إنشاء عملية دفع"

#: apps/audit/models.py:19
msgid "Transaction cancelled"
msgstr "تم إلغاء عملية الدفع"

#: apps/audit/models.py:20
msgid "Settlement created"
msgstr "تم إنشاء التسوية"

#: apps/audit/models.py:23
msgid "Settlement marked settled"
msgstr "تم اعتماد التسوية"

#: apps/bookings/services.py:39
msgid "The selected booking slot is no longer available."
msgstr "وقت الحجز المحدد لم يعد متاحاً."

#: apps/bookings/services.py:41 apps/transactions/services.py:27
msgid "Booking must belong to the selected club."
msgstr "يجب أن ينتمي الحجز إلى النادي المحدد."

#: apps/bookings/services.py:42
msgid "This booking is already cancelled."
msgstr "تم إلغاء هذا الحجز بالفعل."

#: apps/bookings/services.py:44
msgid "This booking status transition is not allowed."
msgstr "تغيير حالة هذا الحجز غير مسموح."

#: apps/common/exceptions.py:9
msgid "An API error occurred."
msgstr "حدث خطأ في واجهة البرمجة."

#: apps/common/exceptions.py:35
msgid "Validation error."
msgstr "خطأ في التحقق من البيانات."

#: apps/settlements/serializers.py:141
msgid "This field is required when creating a settlement."
msgstr "هذا الحقل مطلوب عند إنشاء التسوية."

#: apps/settlements/services.py:15
msgid "There are no unsettled transactions for this user."
msgstr "لا توجد معاملات غير مسواة لهذا المستخدم."

#: apps/settlements/services.py:18
msgid "One or more transactions were already settled. Please retry."
msgstr "تمت تسوية معاملة واحدة أو أكثر بالفعل. يرجى المحاولة مرة أخرى."

#: apps/settlements/services.py:20
msgid "You cannot approve your own settlement."
msgstr "لا يمكنك اعتماد التسوية الخاصة بك."

#: apps/settlements/services.py:21
msgid "This settlement is already settled."
msgstr "تمت تسوية هذه التسوية بالفعل."

#: apps/settlements/services.py:23
msgid "Only pending settlements can be marked as settled."
msgstr "يمكن اعتماد التسويات المعلقة فقط."

#: apps/transactions/services.py:19
msgid "This payment is already cancelled."
msgstr "تم إلغاء عملية الدفع هذه بالفعل."

#: apps/transactions/services.py:21
msgid "Settled payments cannot be cancelled."
msgstr "لا يمكن إلغاء عمليات الدفع التي تمت تسويتها."

#: apps/transactions/services.py:24
msgid "Payments on terminal bookings cannot be cancelled."
msgstr "لا يمكن إلغاء عمليات الدفع الخاصة بالحجوزات النهائية."

#: apps/transactions/services.py:30
msgid "Transactions can only be added to HOLD or CONFIRMED bookings."
msgstr "يمكن إضافة عمليات الدفع إلى حجوزات الانتظار أو المؤكدة فقط."

#~ msgid "You cannot settle your own transactions."
#~ msgstr "لا يمكنك تسوية معاملاتك بنفسك."
