# Copy this file to .env for local development.
# Use a unique secret locally; never commit real secrets.
SECRET_KEY=change-me-for-local-development-only

# Use True only in local development.
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Local default is SQLite.
DB_ENGINE=sqlite
DB_NAME=db.sqlite3

# PostgreSQL example values. Leave blank when using SQLite.
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_SSLMODE=

# Optional local-only SQL request summary logs.
SQL_QUERY_STATS_ENABLED=false
SQL_QUERY_STATS_VERBOSE=false
SQL_QUERY_STATS_SLOW_QUERY_MS=100
